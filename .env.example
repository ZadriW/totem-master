# Copie para .env na raiz do projeto e preencha os valores.
# O arquivo .env não deve ser commitado no Git.

# Token Storefront da Wake Commerce (header TCS-Access-Token).
# Gerado no painel Wake → Storefront API. Formato típico: tcs_<conta>_<hex>
WAKE_TOKEN=

# Opcional: chave secreta fixa para sessões Flask (recomendado em produção)
# TOTEM_SECRET_KEY=

# Opcional: credenciais do painel admin
# TOTEM_ADMIN_USER=
# TOTEM_ADMIN_PASS=
